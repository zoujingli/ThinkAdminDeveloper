{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-account",
  "version": "8.0.x-dev",
  "homepage": "https://thinkadmin.top",
  "description": "Account Plugin for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "ext-gd": "*",
    "ext-curl": "*",
    "ext-json": "*",
    "zoujingli/think-install": "^1.0|@dev",
    "zoujingli/think-library": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5|^10.0"
  },
  "autoload": {
    "psr-4": {
      "plugin\\account\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "think\\admin\\tests\\": "tests/"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\account\\Service"
      ]
    },
    "plugin": {
      "copy": {
        "stc/database": "database/migrations"
      }
    },
    "config": {
      "type": "plugin",
      "name": "用户账号管理",
      "document": "https://thinkadmin.top/plugin/think-plugs-account.html",
      "license": [
        "VIP"
      ]
    }
  },
  "minimum-stability": "dev",
  "config": {
    "allow-plugins": {
      "zoujingli/think-install": true
    }
  }
}
