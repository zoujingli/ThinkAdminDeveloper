{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-account",
  "version": "8.0.x-dev",
  "license": "proprietary",
  "homepage": "https://thinkadmin.top",
  "description": "Account Plugin for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "ext-gd": "*",
    "ext-curl": "*",
    "ext-json": "*",
    "zoujingli/think-plugs-helper": "^8.0",
    "zoujingli/think-library": "^8.0",
    "zoujingli/think-plugs-storage": "^8.0",
    "zoujingli/think-plugs-system": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5|^10.0"
  },
  "autoload": {
    "psr-4": {
      "plugin\\account\\": "src"
    }
  },
  "autoload-dev": {
