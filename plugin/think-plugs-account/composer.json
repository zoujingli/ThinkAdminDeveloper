{
    "type": "think-admin-plugin",
    "name": "zoujingli/think-plugs-account",
    "version": "8.0.x-dev",
    "license": "proprietary",
    "homepage": "https://thinkadmin.top",
    "description": "Account Plugin for ThinkAdmin",
    "authors": [
        {
            "name": "Anyon",
            "email": "zoujingli@qq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-gd": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "zoujingli/think-plugs-helper": "^8.0",
        "zoujingli/think-library": "^8.0",
        "zoujingli/think-plugs-storage": "^8.0",
        "zoujingli/think-plugs-system": "^8.0",
        "zoujingli/think-plugs-wechat-client": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0"
    },
    "autoload": {
        "psr-4": {
            "plugin\\account\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "think\\admin\\tests\\": "tests/"
        }
    },
    "extra": {
        "think": {
            "services": [
                "plugin\\account\\Service"
            ]
        },
        "xadmin": {
            "migrate": {
                "file": "20241010000005_install_account20241010.php",
                "class": "InstallAccount20241010",
                "name": "AccountPlugin"
            },
            "menu": {
                "items": [
                    {
                        "name": "用户管理",
                        "subs": [
                            {
                                "name": "用户账号管理",
                                "icon": "layui-icon layui-icon-user",
                                "node": "account/master/index"
                            },
                            {
                                "name": "终端账号管理",
                                "icon": "layui-icon layui-icon-cellphone",
                                "node": "account/device/index"
                            },
                            {
                                "name": "手机短信管理",
                                "icon": "layui-icon layui-icon-email",
                                "node": "account/message/index"
                            }
                        ]
                    }
                ]
            },
            "app": {
                "name": "账号管理",
                "document": "https://thinkadmin.top/plugin/think-plugs-account.html",
                "license": [
                    "VIP"
                ],
                "code": "account",
                "prefix": "account"
            }
        }
    },
    "minimum-stability": "dev"
}
