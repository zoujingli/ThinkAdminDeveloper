        "class": "InstallAccount20241010",
        "name": "AccountPlugin"
      }
    },
    "config": {
      "type": "plugin",
      "name": "用户账号管理",
      "document": "https://thinkadmin.top/plugin/think-plugs-account.html",
      "license": [
        "VIP"
      ]
    }
  },
  "minimum-stability": "dev"
