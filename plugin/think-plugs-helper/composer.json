{
  "type": "library",
  "name": "zoujingli/think-plugs-helper",
  "version": "8.0.x-dev",
  "license": "Apache-2.0",
  "homepage": "https://thinkadmin.top",
  "description": "Developer Tools for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "ext-zlib": "*",
    "doctrine/dbal": "^4.2",
    "topthink/think-migration": "^3.0",
    "topthink/think-orm": "^4.0",
    "topthink/think-ide-helper": "*",
    "zoujingli/think-library": "^8.0",
    "zoujingli/think-plugs-system": "^8.0",
    "zoujingli/think-plugs-worker": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "plugin\\helper\\": "src"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload-dev": {
    "psr-4": {
      "plugin\\helper\\tests\\": "tests/"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\helper\\Service"
      ]
    },
    "xadmin": {
      "app": {
        "name": "开发者工具",
        "description": "为 ThinkAdmin 提供开发辅助工具、代码生成与调试支持。",
        "code": "helper",
        "prefix": "helper"
      }
    }
  }
}
