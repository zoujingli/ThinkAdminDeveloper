{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-storage",
  "version": "8.0.x-dev",
  "license": "MIT",
  "homepage": "https://thinkadmin.top",
  "description": "Standard storage driver center for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "zoujingli/think-library": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "plugin\\storage\\": "src",
      "think\\admin\\storage\\": "src/storage"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "think\\admin\\tests\\": "tests/"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\storage\\Service"
      ]
    },
    "xadmin": {
      "service": {
        "code": "storage",
        "prefix": "storage",
        "type": "plugin",
        "name": "存储中心"
      },
      "migrate": {
        "file": "20241010000002_install_storage20241010.php",
        "class": "InstallStorage20241010",
        "name": "StoragePlugin"
      }
    },
    "config": {
      "type": "plugin",
      "name": "标准存储管理中心",
      "document": "https://thinkadmin.top/plugin/think-plugs-storage.html",
      "description": "统一管理本地与云存储驱动、上传授权与配置元数据。"
    }
  },
  "minimum-stability": "dev",
  "config": {
    "sort-packages": true
  }
}
