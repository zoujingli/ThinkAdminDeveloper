{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-wuma",
  "version": "8.0.x-dev",
  "license": "proprietary",
  "homepage": "https://thinkadmin.top",
  "description": "Wuma Plugin for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-gd": "*",
    "ext-json": "*",
    "ext-bcmath": "*",
    "zoujingli/think-plugs-helper": "^8.0",
    "zoujingli/think-plugs-storage": "^8.0",
    "zoujingli/think-plugs-system": "^8.0",
    "zoujingli/think-plugs-worker": "^8.0",
    "zoujingli/think-plugs-wemall": "^8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5|^10.0"
  },
  "autoload": {
    "psr-4": {
      "plugin\\wuma\\": "src"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\wuma\\Service"
      ]
    },
    "xadmin": {
      "service": {
        "code": "wuma",
        "prefix": "wuma",
        "type": "module",
        "name": "防伪溯源"
      },
      "migrate": {
        "file": "20241010000010_install_wuma20241010.php",
        "class": "InstallWuma20241010",
        "name": "WumaPlugin"
      }
    },
    "config": {
      "type": "module",
      "name": "物码标签管理",
      "document": "https://thinkadmin.top/plugin/think-plugs-wuma.html",
      "description": "防伪溯源管理模块，提供标签生成及出入库管理。",
      "license": [
        "FEE"
      ]
    }
  },
  "minimum-stability": "dev",
  "config": {
    "sort-packages": true
  }
}
