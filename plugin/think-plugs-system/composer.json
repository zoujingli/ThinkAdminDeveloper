{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-system",
  "version": "8.0.x-dev",
  "license": "MIT",
  "homepage": "https://thinkadmin.top",
  "description": "System Plugin for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "topthink/framework": "^8.1",
    "topthink/think-view": "^2.0",
    "zoujingli/ip2region": "^1.0 || ^2.0 || ^3.0",
    "zoujingli/think-library": "^8.0",
    "zoujingli/think-plugs-static": "^8.0",
    "zoujingli/think-plugs-storage": "^8.0",
    "zoujingli/think-plugs-worker": "^8.0"
  },
  "autoload": {
    "files": [
      "src/common.php"
    ],
    "psr-4": {
      "plugin\\system\\": "src"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload-dev": {
    "psr-4": {
      "plugin\\system\\tests\\": "tests/"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\system\\Service"
      ]
    },
    "xadmin": {
      "service": {
        "code": "system",
        "prefix": "system",
        "type": "plugin",
        "name": "系统管理"
      },
      "menu": {
        "root": {
          "name": "系统管理",
          "sort": 100
        },
        "exists": {
          "url|node": "system/config/index"
        }
      },
      "migrate": {
        "file": "20241010000001_install_system20241010.php",
        "class": "InstallSystem20241010",
        "name": "SystemPlugin"
      }
    },
    "config": {
      "type": "plugin",
      "name": "系统后台管理",
      "document": "https://thinkadmin.top/plugin/think-plugs-system.html",
      "description": "系统后台、权限用户、共享配置与系统运维一体化管理模块。"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "config": {
    "sort-packages": true
  }
}
