{
  "type": "think-admin-plugin",
  "name": "zoujingli/think-plugs-admin",
  "version": "8.0.x-dev",
  "license": "MIT",
  "homepage": "https://thinkadmin.top",
  "description": "Admin Plugin for ThinkAdmin",
  "authors": [
    {
      "name": "Anyon",
      "email": "zoujingli@qq.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "ext-json": "*",
    "topthink/framework": "^8.1",
    "topthink/think-view": "^2.0",
    "zoujingli/ip2region": "^1.0 || ^2.0 || ^3.0",
    "zoujingli/think-plugs-helper": "^8.0",
    "zoujingli/think-library": "^8.0",
    "zoujingli/think-plugs-storage": "^8.0",
    "zoujingli/think-plugs-static": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "plugin\\admin\\": "src"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\admin\\Service"
      ]
    },
    "xadmin": {
      "service": {
        "code": "admin",
        "prefix": "admin",
        "type": "plugin",
        "name": "系统管理"
      },
      "menu": {
        "root": {
          "name": "系统管理",
          "sort": 100
        },
        "exists": {
          "url|node": "admin/config/index"
        }
      },
      "migrate": {
        "file": "20241010000001_install_admin20241010.php",
        "class": "InstallAdmin20241010",
        "name": "AdminPlugin"
      }
    },
    "config": {
      "type": "plugin",
      "name": "系统后台管理",
      "document": "https://thinkadmin.top/plugin/think-plugs-admin.html",
      "description": "后台基础管理模块，系统账号及安全配置管理。"
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "config": {
    "sort-packages": true
  }
}
